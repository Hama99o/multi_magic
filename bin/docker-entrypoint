#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
  LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit 2>/dev/null || true)
  [ -n "$LD_PRELOAD" ] && export LD_PRELOAD
fi

# Run DB setup when starting the server (idempotent: creates + migrates if needed).
if echo "$*" | grep -q "rails server\|puma"; then
  ./bin/rails db:prepare
fi

exec "$@"
