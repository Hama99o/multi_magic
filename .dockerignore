# Git
/.git/
/.gitignore

# Bundle
/.bundle

# Environment files
/.env*

# Keys
/config/master.key
/config/credentials/*.key

# Logs and temp
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Storage
/storage/*
!/storage/.keep

# Node modules (rebuilt in container)
/node_modules/

# Built assets (rebuilt in container)
/app/assets/builds/*
!/app/assets/builds/.keep
/public/assets
/public/vite*

# Coverage
/coverage/*

# Debug logs
npm-debug.log*
# Vite uses dotenv and suggests to ignore local-only env files. See
# https://vitejs.dev/guide/env-and-mode.html#env-files
*.local

# Ignore uncategorized files
.DS_Store
